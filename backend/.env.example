# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Flask runtime environment: development | testing | production
FLASK_ENV=development

# A long random secret string used for session signing.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING

# Comma-separated list of allowed front-end origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Storage ───────────────────────────────────────────────────────────────────
# Absolute or relative path where downloaded videos are cached temporarily
DOWNLOAD_DIR=./downloads

# How long (seconds) downloaded files are kept before the cleaner deletes them
CACHE_TTL_SECONDS=3600

# Maximum video file size the server will stream (bytes) — default 500 MB
MAX_VIDEO_BYTES=524288000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATELIMIT_DEFAULT=60 per minute
RATELIMIT_ANALYZE=20 per minute
RATELIMIT_DOWNLOAD=10 per minute

# Redis URI for multi-worker rate limiting (leave blank for in-memory)
# RATELIMIT_STORAGE_URL=redis://localhost:6379/0

# ── yt-dlp ───────────────────────────────────────────────────────────────────
# Format selector — best MP4 with H.264 video + AAC audio
YTDLP_FORMAT=bestvideo[ext=mp4][vcodec^=avc]+bestaudio[ext=m4a]/best[ext=mp4]/best

# Optional proxy (comment out if not needed)
# YTDLP_PROXY=socks5://127.0.0.1:1080

# Path to a Netscape-format cookies file (for authenticated platforms)
# YTDLP_COOKIES_FILE=/path/to/cookies.txt

# HTTP socket timeout for yt-dlp requests (seconds)
YTDLP_SOCKET_TIMEOUT=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
